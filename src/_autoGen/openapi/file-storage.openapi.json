{
  "openapi": "3.0.1",
  "info": {
    "title": "文件存储服务 API",
    "description": "WisePen 文件上传、下载、删除与回调接口",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://172.28.0.9:19907",
      "description": "Generated server url"
    }
  ],
  "tags": [
    {
      "name": "文件存储",
      "description": "用户文件与图片上传代理接口"
    },
    {
      "name": "内部文件存储",
      "description": "供其他微服务初始化上传、获取下载地址与管理物理文件"
    },
    {
      "name": "外部文件存储",
      "description": "处理云存储服务回调"
    }
  ],
  "paths": {
    "/storage/imageUpload": {
      "post": {
        "tags": ["文件存储"],
        "summary": "上传图床图片",
        "operationId": "uploadImageProxy",
        "parameters": [
          {
            "name": "scene",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "true",
              "enum": [
                "PUBLIC_IMAGE_FOR_USER",
                "PUBLIC_IMAGE_FOR_GROUP",
                "PRIVATE_IMAGE_FOR_NOTE",
                "PRIVATE_DOC",
                "PRIVATE_SKILL_ASSET"
              ]
            }
          },
          {
            "name": "bizTag",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "required": ["file"],
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RStorageRecordDTO"
                }
              }
            }
          }
        },
        "security": [
          {
            "FromSource": [],
            "UserID": [],
            "IdentityType": [],
            "GroupRoleMap": []
          }
        ]
      }
    },
    "/internal/storage/initUpload": {
      "post": {
        "tags": ["内部文件存储"],
        "summary": "内部初始化文件上传",
        "operationId": "initUpload",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UploadInitReqDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RUploadInitRespDTO"
                }
              }
            }
          }
        },
        "security": [
          {
            "FromSource": []
          }
        ]
      }
    },
    "/external/storage/callback/upload": {
      "post": {
        "tags": ["外部文件存储"],
        "summary": "接收上传完成回调",
        "operationId": "handleUploadCallback",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "string"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        },
        "security": [
          {
            "FromSource": []
          }
        ]
      }
    },
    "/internal/storage/getStsToken": {
      "get": {
        "tags": ["内部文件存储"],
        "summary": "内部获取临时访问凭证",
        "operationId": "getStsToken",
        "parameters": [
          {
            "name": "scene",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "PUBLIC_IMAGE_FOR_USER",
                "PUBLIC_IMAGE_FOR_GROUP",
                "PRIVATE_IMAGE_FOR_NOTE",
                "PRIVATE_DOC",
                "PRIVATE_SKILL_ASSET"
              ]
            }
          },
          {
            "name": "bizTag",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "configId",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          },
          {
            "name": "durationSeconds",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "default": 3600
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RStsTokenDTO"
                }
              }
            }
          }
        },
        "security": [
          {
            "FromSource": []
          }
        ]
      }
    },
    "/internal/storage/getFileRecord": {
      "get": {
        "tags": ["内部文件存储"],
        "summary": "内部获取文件记录",
        "operationId": "getFileRecord",
        "parameters": [
          {
            "name": "objectKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RStorageRecordDTO"
                }
              }
            }
          }
        },
        "security": [
          {
            "FromSource": []
          }
        ]
      }
    },
    "/internal/storage/getDownloadUrl": {
      "get": {
        "tags": ["内部文件存储"],
        "summary": "内部获取文件下载地址",
        "operationId": "getDownloadUrl",
        "parameters": [
          {
            "name": "objectKey",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "duration",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int64",
              "default": 900
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RString"
                }
              }
            }
          }
        },
        "security": [
          {
            "FromSource": []
          }
        ]
      }
    },
    "/internal/storage/deleteFiles": {
      "delete": {
        "tags": ["内部文件存储"],
        "summary": "内部物理删除文件",
        "operationId": "deleteFiles",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          }
        },
        "security": [
          {
            "FromSource": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "RStorageRecordDTO": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "key": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/StorageRecordDTO"
          }
        }
      },
      "StorageRecordDTO": {
        "type": "object",
        "properties": {
          "objectKey": {
            "type": "string"
          },
          "md5": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "format": "int64"
          },
          "fileId": {
            "type": "integer",
            "format": "int64"
          },
          "domain": {
            "type": "string"
          }
        }
      },
      "UploadInitReqDTO": {
        "type": "object",
        "properties": {
          "md5": {
            "type": "string"
          },
          "extension": {
            "type": "string"
          },
          "scene": {
            "type": "string",
            "enum": [
              "PUBLIC_IMAGE_FOR_USER",
              "PUBLIC_IMAGE_FOR_GROUP",
              "PRIVATE_IMAGE_FOR_NOTE",
              "PRIVATE_DOC",
              "PRIVATE_SKILL_ASSET"
            ]
          },
          "bizTag": {
            "type": "string"
          },
          "configId": {
            "type": "integer",
            "format": "int64"
          },
          "expectedSize": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "RUploadInitRespDTO": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "key": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/UploadInitRespDTO"
          }
        }
      },
      "UploadInitRespDTO": {
        "type": "object",
        "properties": {
          "putUrl": {
            "type": "string"
          },
          "callbackHeader": {
            "type": "string"
          },
          "flashUploaded": {
            "type": "boolean"
          },
          "domain": {
            "type": "string"
          },
          "objectKey": {
            "type": "string"
          }
        }
      },
      "RStsTokenDTO": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "key": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/StsTokenDTO"
          }
        }
      },
      "StsTokenDTO": {
        "type": "object",
        "properties": {
          "accessKeyId": {
            "type": "string"
          },
          "accessKeySecret": {
            "type": "string"
          },
          "securityToken": {
            "type": "string"
          },
          "bucket": {
            "type": "string"
          },
          "region": {
            "type": "string"
          },
          "expiration": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RString": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "key": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "type": "string"
          }
        }
      },
      "RVoid": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "key": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        }
      }
    },
    "securitySchemes": {
      "FromSource": {
        "type": "apiKey",
        "description": "内部来源校验头。直连微服务测试时填写 APISIX 注入的固定来源值。",
        "name": "X-From-Source",
        "in": "header"
      },
      "UserID": {
        "type": "apiKey",
        "description": "当前用户 ID。直连微服务测试 @CheckLogin 接口时手工模拟 APISIX 注入。",
        "name": "X-User-Id",
        "in": "header"
      },
      "IdentityType": {
        "type": "apiKey",
        "description": "当前用户身份类型：1=学生，2=教师，3=管理员。",
        "name": "X-Identity-Type",
        "in": "header"
      },
      "GroupRoleMap": {
        "type": "apiKey",
        "description": "当前用户小组角色 JSON，例如 {\"10001\":0}，角色值：0=OWNER，1=ADMIN，2=MEMBER。",
        "name": "X-Group-Role-Map",
        "in": "header"
      },
      "Developer": {
        "type": "apiKey",
        "description": "灰度隔离开发者标识。通常由 dev.properties 设置；直连测试时可手工透传。",
        "name": "X-Developer",
        "in": "header"
      }
    }
  }
}
