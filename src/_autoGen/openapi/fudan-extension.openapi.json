{
  "openapi": "3.0.1",
  "info": {
    "title": "复旦扩展服务 API",
    "description": "WisePen 复旦 UIS 认证扩展接口",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://172.28.0.16:20001",
      "description": "Generated server url"
    }
  ],
  "tags": [
    {
      "name": "内部复旦 UIS 认证",
      "description": "供用户服务查询复旦 UIS 认证任务状态"
    }
  ],
  "paths": {
    "/internal/extenion/fudan/uis/getUISVerificationStatus": {
      "get": {
        "tags": ["内部复旦 UIS 认证"],
        "summary": "内部获取复旦 UIS 认证状态",
        "operationId": "getTaskStatus",
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RFudanUISTaskResultDTO"
                }
              }
            }
          }
        },
        "security": [
          {
            "FromSource": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "FudanUISTaskResultDTO": {
        "type": "object",
        "properties": {
          "state": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          },
          "qrBase64": {
            "type": "string"
          },
          "profile": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      },
      "RFudanUISTaskResultDTO": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "key": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/FudanUISTaskResultDTO"
          }
        }
      }
    },
    "securitySchemes": {
      "FromSource": {
        "type": "apiKey",
        "description": "内部来源校验头。直连微服务测试时填写 APISIX 注入的固定来源值。",
        "name": "X-From-Source",
        "in": "header"
      },
      "UserID": {
        "type": "apiKey",
        "description": "当前用户 ID。直连微服务测试 @CheckLogin 接口时手工模拟 APISIX 注入。",
        "name": "X-User-Id",
        "in": "header"
      },
      "IdentityType": {
        "type": "apiKey",
        "description": "当前用户身份类型：1=学生，2=教师，3=管理员。",
        "name": "X-Identity-Type",
        "in": "header"
      },
      "GroupRoleMap": {
        "type": "apiKey",
        "description": "当前用户小组角色 JSON，例如 {\"10001\":0}，角色值：0=OWNER，1=ADMIN，2=MEMBER。",
        "name": "X-Group-Role-Map",
        "in": "header"
      },
      "Developer": {
        "type": "apiKey",
        "description": "灰度隔离开发者标识。通常由 dev.properties 设置；直连测试时可手工透传。",
        "name": "X-Developer",
        "in": "header"
      }
    }
  }
}
