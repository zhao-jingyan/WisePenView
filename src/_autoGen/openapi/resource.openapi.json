            "type": "boolean"
          },
          "taggedResourceAclGrantScope": {
            "type": "string",
            "enum": ["ALL", "ONLY_ADMIN", "WHITELIST", "BLACKLIST"]
          },
          "taggedResourceAclGrantSpecifiedUsers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "taggedResourceGrantedActionsMask": {
            "type": "integer",
            "format": "int32"
          },
          "tagMountPermissionScope": {
            "type": "string",
            "enum": ["ALL", "ONLY_ADMIN", "WHITELIST", "BLACKLIST"]
          },
          "tagMountSpecifiedUsers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "targetTagId": {
            "type": "string"
          },
          "grantedActions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["DISCOVER", "VIEW", "EDIT", "DOWNLOAD_WATERMARK", "DOWNLOAD_ORIGINAL"]
            }
          }
        }
      },
      "TagCreateRequest": {
        "required": ["tagName"],
        "type": "object",
        "properties": {
          "groupId": {
            "type": "string"
          },
          "parentId": {
            "type": "string"
          },
          "tagName": {
            "type": "string"
          },
          "tagDesc": {
            "type": "string"
          },
          "taggedResourceAclGrantScope": {
            "type": "string",
            "enum": ["ALL", "ONLY_ADMIN", "WHITELIST", "BLACKLIST"]
          },
          "taggedResourceAclGrantSpecifiedUsers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "grantedActions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["DISCOVER", "VIEW", "EDIT", "DOWNLOAD_WATERMARK", "DOWNLOAD_ORIGINAL"]
            }
          },
          "tagMountPermissionScope": {
            "type": "string",
            "enum": ["ALL", "ONLY_ADMIN", "WHITELIST", "BLACKLIST"]
          },
          "tagMountSpecifiedUsers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "RString": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "key": {
            "type": "string"
          },
          "msg": {
