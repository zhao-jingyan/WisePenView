            "type": "string"
          },
          "contentSummary": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "mergedCount": {
            "type": "integer",
            "format": "int32"
          },
          "details": {
            "type": "object"
          },
          "id": {
            "type": "string"
          }
        }
      },
      "PageRNoteOperationLogResponse": {
        "type": "object",
        "properties": {
          "list": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NoteOperationLogResponse"
            }
          },
          "total": {
            "type": "integer",
            "format": "int64"
          },
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "size": {
            "type": "integer",
            "format": "int32"
          },
          "totalPage": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "RPageRNoteOperationLogResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "key": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/PageRNoteOperationLogResponse"
          }
        }
      },
      "NoteVersionInfoResponse": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["FULL", "DELTA"]
          },
          "createdBy": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            }
          },
          "version": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "PageRNoteVersionInfoResponse": {
        "type": "object",
        "properties": {
          "list": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NoteVersionInfoResponse"
            }
          },
          "total": {
            "type": "integer",
            "format": "int64"
          },
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "size": {
            "type": "integer",
            "format": "int32"
          },
          "totalPage": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "RPageRNoteVersionInfoResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "key": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
