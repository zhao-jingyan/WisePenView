          "likeCount": {
            "type": "integer",
            "format": "int32"
          },
          "scoreCount": {
            "type": "integer",
            "format": "int32"
          },
          "scoreTotal": {
            "type": "integer",
            "format": "int32"
          },
          "favoriteCount": {
            "type": "integer",
            "format": "int32"
          },
