{
  "openapi": "3.0.1",
  "info": {
    "title": "笔记服务 API",
    "description": "WisePen 笔记内容、操作日志与详情接口",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://172.28.0.25:19908",
      "description": "Generated server url"
    }
  ],
  "tags": [
    {
      "name": "笔记",
      "description": "笔记创建、详情查询、版本列表和版本回退"
    },
    {
      "name": "内部 - 笔记",
      "description": "供 Node.js 协同服务和业务微服务读取笔记快照"
    },
    {
      "name": "笔记日志",
      "description": "查看笔记的细粒度操作日志"
    }
  ],
  "paths": {
    "/note/revertNote": {
      "post": {
        "tags": ["笔记"],
        "summary": "回退笔记版本",
        "description": "- 用途：预留给笔记所有者将笔记回退到指定历史版本。\n- 请求：resourceId 指定笔记资源；version 指定目标版本号。\n- 约束：当前用户必须已登录，且必须是资源所有者。\n- 处理：当前接口仅完成所有者权限校验，实际回退逻辑尚未实现；不会修改笔记内容、版本记录或协同状态。\n- 失败：未登录 -> PermissionError.NOT_LOGIN；当前用户不是资源所有者 -> NoteError.NOTE_PERMISSION_DENIED；权限计算发生未处理异常 -> CommonError.INTERNAL_ERROR。\n- 响应：成功时返回空结果。\n",
        "operationId": "revertToVersion",
        "parameters": [
          {
            "name": "resourceId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "version",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          }
        },
        "security": [
          {
            "FromSource": [],
            "UserID": [],
            "IdentityType": [],
            "GroupRoleMap": []
          }
        ]
      }
    },
    "/note/addNote": {
      "post": {
        "tags": ["笔记"],
        "summary": "创建笔记",
        "description": "- 用途：为当前用户创建一份新的协同笔记资源。\n- 请求：title 为笔记标题。\n- 约束：当前用户必须已登录；title 必须是可用于展示的笔记标题。\n- 处理：调用资源服务注册 NOTE 类型资源，以当前用户作为所有者；随后创建笔记信息记录并将当前用户写入作者列表；不创建初始协同快照。\n- 失败：未登录 -> PermissionError.NOT_LOGIN；资源注册失败或笔记信息落库失败 -> NoteError.NOTE_REGISTER_RESOURCE_FAILED。\n- 响应：返回新笔记的资源 ID。\n",
        "operationId": "createNote",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/NoteCreateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RString"
                }
              }
            }
          }
        },
        "security": [
          {
            "FromSource": [],
            "UserID": [],
            "IdentityType": [],
            "GroupRoleMap": []
          }
        ]
      }
    },
    "/note/log/getNoteOpLogs": {
      "get": {
        "tags": ["笔记日志"],
        "summary": "分页查询笔记操作日志",
        "description": "- 用途：查看指定笔记的协同编辑操作日志。\n- 请求：resourceId 指定笔记资源；page 和 size 控制分页。\n- 约束：当前用户必须已登录；本接口当前不单独校验资源查看权限。\n- 处理：按 resourceId 和时间倒序分页读取操作日志；不返回笔记快照，也不修改日志记录。\n- 失败：未登录 -> PermissionError.NOT_LOGIN；日志查询发生未处理异常 -> CommonError.INTERNAL_ERROR。\n- 响应：返回分页操作日志列表和总数。\n",
        "operationId": "listNoteOperationLogs",
        "parameters": [
          {
            "name": "resourceId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RPageRNoteOperationLogResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "FromSource": [],
            "UserID": [],
            "IdentityType": [],
            "GroupRoleMap": []
          }
        ]
      }
    },
    "/note/listNoteHistoryVersions": {
      "get": {
        "tags": ["笔记"],
        "summary": "分页查询笔记版本",
        "description": "- 用途：查询笔记的历史版本列表，供所有者查看版本轨迹。\n- 请求：resourceId 指定笔记资源；page 和 size 控制分页。\n- 约束：当前用户必须已登录，且必须是资源所有者。\n- 处理：通过资源服务校验所有者身份后，按版本号倒序分页读取版本记录；不返回版本快照正文，不执行版本回退。\n- 失败：未登录 -> PermissionError.NOT_LOGIN；当前用户不是资源所有者 -> NoteError.NOTE_PERMISSION_DENIED；权限计算发生未处理异常 -> CommonError.INTERNAL_ERROR。\n- 响应：返回分页版本摘要列表和总数。\n",
        "operationId": "listNoteHistoryVersions",
        "parameters": [
          {
            "name": "resourceId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 20
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RPageRNoteVersionListResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "FromSource": [],
            "UserID": [],
            "IdentityType": [],
            "GroupRoleMap": []
          }
        ]
      }
    },
    "/note/getNoteInfo": {
      "get": {
        "tags": ["笔记"],
        "summary": "获取笔记信息",
        "description": "- 用途：获取笔记资源详情、笔记元信息和作者展示信息。\n- 请求：resourceId 指定笔记资源。\n- 约束：当前用户必须已登录，且必须通过资源服务的资源详情权限校验；目标笔记必须存在。\n- 处理：通过资源服务获取资源详情和当前用户动作集合，读取笔记信息，并尽量调用用户服务补充作者展示信息；作者展示信息补充失败时不阻断主响应。\n- 失败：未登录 -> PermissionError.NOT_LOGIN；资源不存在 -> ResourceError.RESOURCE_NOT_FOUND；资源无查看权限 -> ResourceError.RESOURCE_PERMISSION_DENIED；笔记不存在 -> NoteError.NOTE_NOT_FOUND。\n- 响应：返回资源信息、笔记信息和可用的作者展示信息。\n",
        "operationId": "getNoteInfo",
        "parameters": [
          {
            "name": "resourceId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RNoteInfoResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "FromSource": [],
            "UserID": [],
            "IdentityType": [],
            "GroupRoleMap": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "RVoid": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "key": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "type": "object"
          }
        }
      },
      "NoteCreateRequest": {
        "required": ["title"],
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          }
        }
      },
      "RString": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "key": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "type": "string"
          }
        }
      },
      "NoteOperationLogResponse": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string"
          },
          "operationType": {
            "type": "string"
          },
          "contentSummary": {
            "type": "string"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "mergedCount": {
            "type": "integer",
            "format": "int32"
          },
          "details": {
            "type": "object"
          },
          "id": {
            "type": "string"
          }
        }
      },
      "PageRNoteOperationLogResponse": {
        "type": "object",
        "properties": {
          "list": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NoteOperationLogResponse"
            }
          },
          "total": {
            "type": "integer",
            "format": "int64"
          },
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "size": {
            "type": "integer",
            "format": "int32"
          },
          "totalPage": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "RPageRNoteOperationLogResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "key": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/PageRNoteOperationLogResponse"
          }
        }
      },
      "NoteVersionListResponse": {
        "type": "object",
        "properties": {
          "version": {
            "type": "integer",
            "format": "int64"
          },
          "type": {
            "type": "string",
            "enum": ["FULL", "DELTA"]
          },
          "label": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "createdBy": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            }
          },
          "id": {
            "type": "string"
          }
        }
      },
      "PageRNoteVersionListResponse": {
        "type": "object",
        "properties": {
          "list": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NoteVersionListResponse"
            }
          },
          "total": {
            "type": "integer",
            "format": "int64"
          },
          "page": {
            "type": "integer",
            "format": "int32"
          },
          "size": {
            "type": "integer",
            "format": "int32"
          },
          "totalPage": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "RPageRNoteVersionListResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "key": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/PageRNoteVersionListResponse"
          }
        }
      },
      "NoteInfoBase": {
        "type": "object",
        "properties": {
          "lastUpdatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int64"
            }
          }
        }
      },
      "NoteInfoResponse": {
        "type": "object",
        "properties": {
          "resourceInfo": {
            "$ref": "#/components/schemas/ResourceItemResponse"
          },
          "noteInfo": {
            "$ref": "#/components/schemas/NoteInfoBase"
          },
          "authorsDisplay": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/UserDisplayBase"
            }
          }
        }
      },
      "RNoteInfoResponse": {
        "type": "object",
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "key": {
            "type": "string"
          },
          "msg": {
            "type": "string"
          },
          "data": {
            "$ref": "#/components/schemas/NoteInfoResponse"
          }
        }
      },
      "ResourceInteractionInfoBase": {
        "type": "object",
        "properties": {
          "readCount": {
            "type": "integer",
            "format": "int32"
          },
          "likeCount": {
            "type": "integer",
            "format": "int32"
          },
          "scoreCount": {
            "type": "integer",
            "format": "int32"
          },
          "scoreTotal": {
            "type": "integer",
            "format": "int32"
          }
        }
      },
      "ResourceItemResponse": {
        "type": "object",
        "properties": {
          "resourceName": {
            "type": "string"
          },
          "resourceType": {
            "type": "string",
            "enum": [
              "NOTE",
              "PDF",
              "DOC",
              "DOCX",
              "PPT",
              "PPTX",
              "XLS",
              "XLSX",
              "SKILL",
              "AGENT",
              "UNKNOWN"
            ]
          },
          "ownerId": {
            "type": "string"
          },
          "preview": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "format": "int64"
          },
          "resourceId": {
            "type": "string"
          },
          "ownerInfo": {
            "$ref": "#/components/schemas/UserDisplayBase"
          },
          "resourceInteractionInfo": {
            "$ref": "#/components/schemas/ResourceInteractionInfoBase"
          },
          "currentTags": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            }
          },
          "currentActions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["DISCOVER", "VIEW", "EDIT", "DOWNLOAD_WATERMARK", "DOWNLOAD_ORIGINAL"]
            }
          },
          "overrideGrantedActions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["DISCOVER", "VIEW", "EDIT", "DOWNLOAD_WATERMARK", "DOWNLOAD_ORIGINAL"]
            }
          },
          "specifiedUsersGrantedActions": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["DISCOVER", "VIEW", "EDIT", "DOWNLOAD_WATERMARK", "DOWNLOAD_ORIGINAL"]
              }
            }
          }
        }
      },
      "UserDisplayBase": {
        "type": "object",
        "properties": {
          "nickname": {
            "type": "string"
          },
          "realName": {
            "type": "string"
          },
          "avatar": {
            "type": "string"
          },
          "identityType": {
            "type": "string",
            "enum": ["1", "2", "3"]
          }
        }
      }
    },
    "securitySchemes": {
      "FromSource": {
        "type": "apiKey",
        "description": "内部来源校验头。直连微服务测试时填写 APISIX 注入的固定来源值。",
        "name": "X-From-Source",
        "in": "header"
      },
      "UserID": {
        "type": "apiKey",
        "description": "当前用户 ID。直连微服务测试 @CheckLogin 接口时手工模拟 APISIX 注入。",
        "name": "X-User-Id",
        "in": "header"
      },
      "IdentityType": {
        "type": "apiKey",
        "description": "当前用户身份类型：1=学生，2=教师，3=管理员。",
        "name": "X-Identity-Type",
        "in": "header"
      },
      "GroupRoleMap": {
        "type": "apiKey",
        "description": "当前用户小组角色 JSON，例如 {\"10001\":0}，角色值：0=OWNER，1=ADMIN，2=MEMBER。",
        "name": "X-Group-Role-Map",
        "in": "header"
      }
    }
  }
}
