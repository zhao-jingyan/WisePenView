{
  "name": "wise-pen-view",
  "private": true,
  "version": "0.6.7",
  "type": "module",
  "main": ".electron/main/index.js",
  "packageManager": "pnpm@11.13.1",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "concurrently -k -s first \"pnpm dev\" \"pnpm build:electron --watch\" \"pnpm dev:electron\"",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 file:.electron/main/index.js file:.electron/preload/index.cjs && cross-env ELECTRON_RENDERER_URL=http://local.wisepen.oriole.cn:5173 electron .electron/main/index.js",
    "mock": "vite --mode mock",
    "build": "tsc -b && vite build",
    "build:dev": "tsc -b && vite build --mode development",
    "build:electron": "node scripts/build-electron.mjs",
    "package:desktop": "pnpm build && pnpm build:electron && electron-builder",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "prepare": "husky install"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.156",
    "@base-ui/react": "^1.6.0",
    "@blocknote/code-block": "0.47.3",
    "@blocknote/core": "^0.47.1",
    "@blocknote/mantine": "^0.47.1",
    "@blocknote/react": "^0.47.1",
    "@dnd-kit/core": "^6.3.1",
    "@embedpdf/react-pdf-viewer": "^2.14.0",
    "@emoji-mart/data": "^1.2.1",
    "@fontsource-variable/noto-sans-sc": "^5.3.0",
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "@incremark/core": "^1.0.2",
    "@lobehub/icons-static-svg": "^1.91.0",
    "@monaco-editor/react": "^4.7.0",
    "@onlyoffice/doceditor-types": "^9.4.0",
    "@onlyoffice/document-editor-react": "^2.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tiptap/pm": "3.20.1",
    "ahooks": "^3.9.7",
    "ai": "^6.0.154",
    "ali-oss": "^6.23.0",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "emoji-mart": "^5.6.0",
    "i18next": "^26.0.10",
    "jszip": "^3.10.1",
    "katex": "^0.16.42",
    "lucide-react": "^0.575.0",
    "mermaid": "11.16.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-error-boundary": "^6.1.2",
    "react-i18next": "^17.0.7",
    "react-resizable-panels": "^4.12.1",
    "react-router-dom": "^7.10.1",
    "shiki": "3.23.0",
    "spark-md5": "^3.0.2",
    "y-indexeddb": "^9.0.12",
    "y-prosemirror": "^1.3.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.1",
    "@types/ali-oss": "^6.23.3",
    "@types/katex": "^0.16.8",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/spark-md5": "^3.0.5",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.27.7",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^8.0.0",
    "less": "^4.4.2",
    "lint-staged": "^16.3.3",
    "prettier": "^3.7.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^9.1.0"
  },
  "build": {
    "appId": "cn.oriole.wisepen",
    "productName": "WisePen",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      ".electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "node scripts/organize-imports.mjs",
      "eslint --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.js": "prettier --write",
    "*.jsx": "prettier --write",
    "*.json": "prettier --write",
    "*.md": "prettier --write"
  }
}
