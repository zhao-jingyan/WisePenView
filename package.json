    "@onlyoffice/document-editor-react": "^2.2.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tiptap/pm": "3.20.1",
    "ahooks": "^3.9.7",
    "ai": "^6.0.154",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
